# SonarQube server base URL (no trailing slash)
SONARQUBE_URL=http://localhost:9000

# User or project token with Browse permission on the target project
SONARQUBE_TOKEN=your_token_here

# SonarQube project key (as shown in the project settings)
SONARQUBE_PROJECT_KEY=your_project_key

# Optional: folder where output runs are stored (default: ./output)
OUTPUT_DIR=./output
